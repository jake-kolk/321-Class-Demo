namespace SpreadsheetEngine
{
    using System;

    /// <summary>
    /// Represents an undo or redo command.
    /// </summary>
    public class RevisionCommand : Command
    {
        private readonly string direction;

        /// <summary>
        /// Initializes a new instance of the <see cref="RevisionCommand"/> class.
        /// </summary>
        /// <param name="direction">Either <c>UNDO</c> or <c>REDO</c>.</param>
        public RevisionCommand(string direction)
            : base("UNDO/REDO")
        {
            if (direction != "UNDO" && direction != "REDO")
            {
                throw new ArgumentOutOfRangeException(nameof(direction), direction, "Must be REDO or UNDO!");
            }

            this.direction = direction;
        }

        /// <summary>
        /// Gets the revision direction.
        /// </summary>
        /// <returns><c>UNDO</c> or <c>REDO</c>.</returns>
        public string GetDirection()
        {
            return this.direction;
        }
    }
}
