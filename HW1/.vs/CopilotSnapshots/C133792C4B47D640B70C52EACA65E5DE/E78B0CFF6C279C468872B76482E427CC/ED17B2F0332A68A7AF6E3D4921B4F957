#pragma warning disable SA1649
namespace SpreadsheetEngine
{
    using System.ComponentModel;

    /// <summary>
    /// Represents an abstract base class for a single cell in the spreadsheet.
    /// </summary>
    public abstract class Cell : INotifyPropertyChanged
    {
        /// <summary>
        /// The raw text entered into the cell.
        /// </summary>
        private string mText = string.Empty;

        /// <summary>
        /// The evaluated value of the cell.
        /// </summary>
        private string mValue = string.Empty;

        /// <summary>
        /// Initializes a new instance of the <see cref="Cell"/> class.
        /// </summary>
        /// <param name="rowIndex">The zero-based row index of the cell.</param>
        /// <param name="columnIndex">The zero-based column index of the cell.</param>
        protected Cell(int rowIndex, int columnIndex)
        {
            this.RowIndex = rowIndex;
            this.ColumnIndex = columnIndex;
        }

        /// <summary>
        /// Occurs when a property value changes.
        /// </summary>
        public event PropertyChangedEventHandler? PropertyChanged;

        /// <summary>
        /// Gets the zero-based row index of this cell.
        /// </summary>
        public int RowIndex { get; }

        /// <summary>
        /// Gets the zero-based column index of this cell.
        /// </summary>
        public int ColumnIndex { get; }

        /// <summary>
        /// Gets or sets the raw text content of the cell.
        /// Setting this property fires <see cref="PropertyChanged"/> only when the value actually changes.
        /// </summary>
        public string Text
        {
            get => this.mText;
            set
            {
                this.mText = value;
                this.PropertyChanged?.Invoke(this, new PropertyChangedEventArgs("Text"));
            }
        }

        /// <summary>
        /// Stores Color attribute.
        /// </summary>
        public uint Color // Default to white
        {
            get => this.Color;
            set
            {
                this.Color = value;
                this.PropertyChanged?.Invoke(this, new PropertyChangedEventArgs("Color"));
            }
        }

        /// <summary>
        /// Gets or sets mValue.
        /// </summary>
        public string Value
        {
            get => this.mValue;
            set
            {
                this.mValue = value;
            }
        }
    }
}