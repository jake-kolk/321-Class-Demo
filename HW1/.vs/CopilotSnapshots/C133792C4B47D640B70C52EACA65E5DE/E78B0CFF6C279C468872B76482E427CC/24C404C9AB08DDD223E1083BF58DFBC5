namespace SpreadsheetEngine
{
    using System;
    using System.Collections.Generic;
    using System.ComponentModel;
    using System.Linq.Expressions;
    using System.Runtime.CompilerServices;
    using System.Text.RegularExpressions;
    using System.Transactions;

    /// <summary>
    /// Represents a spreadsheet engine that manages a two-dimensional collection of cells.
    /// </summary>
    public partial class Spreadsheet
    {
        /// <summary>
        /// Backing storage for all spreadsheet cells.
        /// </summary>
        private readonly SpreadsheetCell[,] cells;

        /// <summary>
        /// Manager for commands issued to this sheet.
        /// </summary>
        public readonly CommandManager Manager = new ();

        /// <summary>
        /// Maps cell names to the list of cells that depend on them.
        /// </summary>
        private readonly Dictionary<string, List<SpreadsheetCell>> dependencyMap = new ();

        /// <summary>
        /// Initializes a new instance of the <see cref="Spreadsheet"/> class.
        /// </summary>
        /// <param name="rows">The number of rows in the spreadsheet.</param>
        /// <param name="columns">The number of columns in the spreadsheet.</param>
        public Spreadsheet(int rows, int columns)
        {
            this.RowCount = rows;
            this.ColumnCount = columns;

            this.cells = new SpreadsheetCell[rows, columns];

            // Initialize all cells and subscribe to their PropertyChanged events
            for (int r = 0; r < rows; r++)
            {
                for (int c = 0; c < columns; c++)
                {
                    this.cells[r, c] = new SpreadsheetCell(r, c, this.ResolveVariable, this.RegisterDependency);
                    this.cells[r, c].PropertyChanged += this.OnCellPropertyChanged;
                }
            }
        }

        /// <summary>
        /// Occurs when a cell's evaluated value changes.
        /// </summary>
        public event PropertyChangedEventHandler? CellPropertyChanged;

        /// <summary>
        /// Gets the number of rows in the spreadsheet.
        /// </summary>
        public int RowCount { get; }

        /// <summary>
        /// Gets the number of columns in the spreadsheet.
        /// </summary>
        public int ColumnCount { get; }

        /// <summary>
        /// Gets the cell at the specified row and column index.
        /// </summary>
        /// <param name="rowIndex">The zero-based row index.</param>
        /// <param name="columnIndex">The zero-based column index.</param>
        /// <returns>
        /// The <see cref="Cell"/> at the specified location, or <c>null</c> if the indices are out of bounds.
        /// </returns>
        public Cell? GetCell(int rowIndex, int columnIndex)
        {
            if (rowIndex < 0 || rowIndex >= this.RowCount ||
                columnIndex < 0 || columnIndex >= this.ColumnCount)
            {
                return null;
            }

            return this.cells[rowIndex, columnIndex];
        }

        /// <summary>
        /// Notifies the UI that the cell at the given position has changed.
        /// </summary>
        /// <param name="rowIndex">The zero-based row index of the cell.</param>
        /// <param name="colIndex">The zero-based column index of the cell.</param>
        public void UpdateCell(int rowIndex, int colIndex)
        {
            SpreadsheetCell? cell = (SpreadsheetCell?)this.GetCell(rowIndex, colIndex);
            this.CellPropertyChanged?.Invoke(cell, new PropertyChangedEventArgs("Value"));
        }

        /// <summary>
        /// Parses a cell name string (e.g., "A1") and returns the corresponding cell object.
        /// </summary>
        /// <param name="name">Name of cell.</param>
        /// <returns>Cell object.</returns>
        private Cell? GetCell(string name)
        {
            string letters = new (name.TakeWhile(c => char.IsLetter(c)).ToArray());
            string numbers = new (name.SkipWhile(c => char.IsLetter(c)).ToArray());
            int column = letters.Sum(c => c - 'A' + 1);
            int row = int.Parse(numbers);
            return this.GetCell(column - 1, row - 1);
        }

        /// <summary>
        /// Registers a cell as a dependant of the given dependency cell names.
        /// Clears stale dependencies before registering new ones.
        /// </summary>
        /// <param name="dependantCell">The cell that depends on others.</param>
        /// <param name="dependencyNames">The names of cells that the dependant relies on.</param>
        private void RegisterDependency(SpreadsheetCell dependantCell, List<string> dependencyNames)
        {
            // Clear old dependencies first to handle formula changes
            foreach (var entry in this.dependencyMap.Values)
            {
                entry.Remove(dependantCell);
            }

            foreach (string name in dependencyNames)
            {
                if (!this.dependencyMap.TryGetValue(name, out List<SpreadsheetCell>? value))
                {
                    value = new List<SpreadsheetCell>();
                    this.dependencyMap[name] = value;
                }

                value.Add(dependantCell);
            }
        }

        /// <summary>
        /// Returns the list of cells that depend on the given cell.
        /// </summary>
        /// <param name="cell">The cell to look up dependants for.</param>
        /// <returns>List of dependant cells.</returns>
        private List<SpreadsheetCell> GetDependants(SpreadsheetCell cell)
        {
            string name = cell.Name;
            return this.dependencyMap.TryGetValue(name, out var list) ? list : new List<SpreadsheetCell>();
        }

        /// <summary>
        /// Recalculates the value of the given cell, notifies the UI, and propagates
        /// the change to any cells that depend on it.
        /// </summary>
        /// <param name="cell">The cell to recalculate.</param>
        private void RecalculateCell(SpreadsheetCell cell)
        {
            // Account for case where cell is not numeric
            if (!cell.Text.StartsWith("=") && !double.TryParse(cell.Text, out double parsed))
            {
                cell.SetValue(cell.Text);
                return;
            }

            // Account for case where equation has string reult (VariableNode only)
            if (MyRegex().IsMatch(cell.Text[1..]) &&
                !double.TryParse(this.ResolveVariable(cell.Text[1..]), out _))
            {
                // Substring(1) for removing '='
                cell.SetValue(this.ResolveVariable(cell.Text[1..]));

                // Notify UI of value change
                this.CellPropertyChanged?.Invoke(cell, new PropertyChangedEventArgs("Value"));
                return;
            }

            try
            {
                double value = cell.RecalculateValue();
                cell.SetValue(value.ToString());
            }
            catch (Exception ex)
            {
                cell.SetValue(ex.Message);
            }

            // Notify UI of value change
            this.CellPropertyChanged?.Invoke(cell, new PropertyChangedEventArgs("Value"));

            // Propagate to dependants recursively
            foreach (SpreadsheetCell dependant in this.GetDependants(cell).ToList())
            {
                this.RecalculateCell(dependant);
            }
        }

        /// <summary>
        /// Handles property change notifications from individual cells.
        /// </summary>
        /// <param name="sender">The cell that triggered the event.</param>
        /// <param name="e">The event data containing the property name.</param>
        /// <remarks>
        /// When the <c>Text</c> property changes, the cell value is recalculated.
        /// After evaluation, the <see cref="CellPropertyChanged"/> event is raised
        /// to notify the UI of a value change.
        /// </remarks>
        private void OnCellPropertyChanged(object? sender, PropertyChangedEventArgs e)
        {
            if (sender is SpreadsheetCell cell)
            {
                if (e.PropertyName == "Text")
                {
                    this.RecalculateCell(cell);
                    this.CellPropertyChanged?.Invoke(cell, new PropertyChangedEventArgs("Value"));
                }
                else if (e.PropertyName == "Color")
                {
                    this.CellPropertyChanged?.Invoke(cell, new PropertyChangedEventArgs("Color"));
                }
            }
        }

        /// <summary>
        /// Parses a cell reference string (e.g., "A1") and returns the corresponding cell.
        /// </summary>
        /// <param name="cellRef">The cell reference string.</param>
        /// <returns>
        /// The referenced <see cref="Cell"/> if valid; otherwise, <c>null</c>.
        /// </returns>
        private Cell? ParseCellReference(string cellRef)
        {
            if (string.IsNullOrEmpty(cellRef))
            {
                return null;
            }

            // First character should be the column letter (e.g. 'A' - 'Z')
            char colChar = char.ToUpper(cellRef[0]);
            if (colChar < 'A' || colChar > 'Z')
            {
                return null;
            }

            // Remaining characters should be the row number (1-based)
            if (!int.TryParse(cellRef[1..], out int rowNumber))
            {
                return null;
            }

            int colIndex = colChar - 'A';
            int rowIndex = rowNumber - 1;

            return this.GetCell(rowIndex, colIndex);
        }

        /// <summary>
        /// Resolves a cell name to its current string value for use in expression evaluation.
        /// </summary>
        /// <param name="cellName">Name of cell being looked up.</param>
        /// <returns>String value of the cell, or an error string if the reference is invalid.</returns>
        private string ResolveVariable(string cellName)
        {
            Cell? cell = this.ParseCellReference(cellName);
            return cell != null ? cell.Value : "!(bad reference)";
        }

        /// <summary>
        /// Represents a spreadsheet cell implementation used internally by the engine.
        /// </summary>
        /// <remarks>
        /// This class is private and not exposed outside the spreadsheet library.
        /// It allows controlled modification of the cell value.
        /// </remarks>
        private class SpreadsheetCell : Cell
        {
            /// <summary>
            /// The expression tree used to evaluate this cell's formula.
            /// </summary>
            private ExpressionTree? tree;

            /// <summary>
            /// Delegate used to resolve variable names to their current cell values.
            /// </summary>
            private readonly Func<string, string> variableResolver;

            /// <summary>
            /// Delegate used to register this cell's dependencies in the spreadsheet.
            /// </summary>
            private readonly Action<SpreadsheetCell, List<string>> registerDependency;

            /// <summary>
            /// The list of cell names this cell depends on.
            /// </summary>
            private List<string> dependancies;

            /// <summary>
            /// Initializes a new instance of the <see cref="SpreadsheetCell"/> class.
            /// </summary>
            /// <param name="rowIndex">The zero-based row index.</param>
            /// <param name="columnIndex">The zero-based column index.</param>
            /// <param name="variableResolver">Delegate to resolve cell name references to values.</param>
            /// <param name="registerDependency">Delegate to register this cell's dependencies.</param>
            public SpreadsheetCell(
                int rowIndex,
                int columnIndex,
                Func<string, string> variableResolver,
                Action<SpreadsheetCell, List<string>> registerDependency)
                : base(rowIndex, columnIndex)
            {
                this.dependancies = new List<string>();
                this.variableResolver = variableResolver;
                this.registerDependency = registerDependency;
            }

            /// <summary>
            /// Gets the name of this cell (e.g., "A1") derived from its row and column index.
            /// </summary>
            public string Name => (char)('A' + this.ColumnIndex) + (this.RowIndex + 1).ToString();

            /// <summary>
            /// Sets the evaluated value of the cell.
            /// </summary>
            /// <param name="value">The value to assign.</param>
            public void SetValue(string value)
            {
                this.Value = value;
            }

            /// <summary>
            /// Rebuilds the expression tree from the cell's text, updates dependencies,
            /// and evaluates the formula to return a numeric result.
            /// </summary>
            /// <returns>The evaluated numeric value of the cell's expression.</returns>
            public double RecalculateValue()
            {
                string expression = this.Text[1..].Trim();
                this.tree = new ExpressionTree(this.Text, this.variableResolver);
                this.dependancies = this.tree.GetDependancies();
                this.registerDependency(this, this.dependancies);
                double value = this.tree.Evaluate();
                return value;
            }
        }

        [GeneratedRegex("^[A-Z]+\\d+$")]
        private static partial Regex MyRegex();
    }
}